    "def rgb_to_bw(img):\n",
    "    #Convertit une image RGB en Noir et Blanc\n",
    "    weights = np.array([0.299, 0.587, 0.114])\n",
    "    gray = np.dot(img[..., :3], weights)/255.0\n",
    "    return gray.astype(np.float32)"
   ]
