    "class MLP(nn.Module):\n",
    "    def __init__(self, H=2):\n",
    "        super().__init__()\n",
    "        # Couche d'entrée : 1024 pixels -> 512 neurones\n",
    "        self.input_layer = nn.Linear(1024, 512)\n",
    "        # Liste de couches cachées pour une gestion flexible\n",
    "        layers = []\n",
    "        layers.append(nn.Linear(512, 512))\n",
    "        layers.append(nn.Linear(512, 256))\n",
    "        layers.append(nn.Linear(256, 128))\n",
    "        self.hidden_layers = nn.ModuleList(layers)\n",
    "        # Couche de sortie : 128 -> 10 classes\n",
    "        self.output_layer = nn.Linear(128, 10)\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = F.relu(self.input_layer(x)) # Activation ReLU sur l'entrée\n",
    "        for layer in self.hidden_layers:\n",
    "            x = F.relu(layer(x)) # Activation ReLU sur les couches cachées\n",
    "        return self.output_layer(x) "
   ]
